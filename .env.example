# ═══════════════════════════════════════════════════════════════════
# WILLIAM OS — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
BASE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://william:william@localhost:5432/williamos

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
OFFLINE_QUEUE_PATH=./data/offline_queue.jsonl

# ── Security (REQUIRED IN PRODUCTION) ─────────────────────────────
# Generate secure values:
#   openssl rand -base64 48
#   openssl rand -hex 32
JWT_SECRET_KEY=
ENCRYPTION_MASTER_SALT=

# ── Gemini AI (Schedule Generation) ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ── OpenRouter (Health AI) ──────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# ── Whisper (Voice Transcription) ───────────────────────────────
WHISPER_API_KEY=your-openai-key

# ── Gmail Intelligence ──────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── OpenClaw Gateway ────────────────────────────────────────────
WILLIAM_API_BASE_URL=http://localhost:8000/api/v1
WILLIAM_GATEWAY_BEARER_TOKEN=
WILLIAM_GATEWAY_TIMEOUT_SECONDS=20
OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_WHATSAPP_TOKEN=
OPENCLAW_DISCORD_TOKEN=

# Grafana monitoring dashboard password
GRAFANA_ADMIN_PASSWORD=your-grafana-password-here

# ── Observability ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
OTEL_ENABLED=true
OTEL_SERVICE_NAME=william-os-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLE_RATE=0.2
OTEL_EXPORTER_TIMEOUT_SECONDS=10

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
