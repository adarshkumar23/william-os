# ═══════════════════════════════════════════════════════════════════
# WILLIAM OS — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
BASE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://william:william@localhost:5432/williamos

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security (CHANGE THESE IN PRODUCTION!) ───────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me
ENCRYPTION_MASTER_SALT=your-super-secret-salt-change-me

# ── Gemini AI (Schedule Generation) ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ── OpenRouter (Health AI) ──────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# ── Whisper (Voice Transcription) ───────────────────────────────
WHISPER_API_KEY=your-openai-key

# ── Gmail Intelligence ──────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
